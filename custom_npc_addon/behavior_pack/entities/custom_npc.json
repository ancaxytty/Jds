{
  "format_version": "1.19.0",
  "minecraft:entity": {
    "description": {
      "identifier": "custom:npc",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "custom:trader_mode": {
        "minecraft:trade_table": {
          "display_name": "Custom NPC",
          "table": "trading/custom_npc_trades.json"
        },
        "minecraft:interact": {
          "interactions": [
            {
              "on_interact": {
                "filters": {
                  "all_of": [
                    {
                      "test": "is_family",
                      "subject": "other",
                      "value": "player"
                    }
                  ]
                }
              },
              "use_item": false,
              "interact_text": "action.interact.trade"
            }
          ]
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["custom_npc", "npc", "mob"]
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.8
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:nameable": {
        "always_show": true,
        "allow_name_tag_renaming": true,
        "default_trigger": {
          "event": "custom:become_trader"
        }
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:damage_sensor": {
        "triggers": {
          "cause": "all",
          "deals_damage": true
        }
      },
      "minecraft:behavior.look_at_player": {
        "priority": 8,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9
      },
      "minecraft:behavior.random_stroll": {
        "priority": 6,
        "speed_multiplier": 0.6
      },
      "minecraft:behavior.float": {
        "priority": 0
      }
    },
    "events": {
      "custom:become_trader": {
        "add": {
          "component_groups": ["custom:trader_mode"]
        }
      },
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["custom:trader_mode"]
        }
      }
    }
  }
}
