{
  "format_version": "1.21.0",
  "minecraft:entity": {
    "description": {
      "identifier": "custom:npc",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "custom:skin": {
          "type": "int",
          "range": [0, 37],
          "default": 0,
          "client_sync": true
        },
        "custom:model": {
          "type": "int",
          "range": [0, 30],
          "default": 0,
          "client_sync": true
        },
        "custom:anim": {
          "type": "int",
          "range": [0, 4],
          "default": 0,
          "client_sync": true
        }
      }
    },

    "component_groups": {
      "npc:size_xs": { "minecraft:scale": { "value": 0.5 } },
      "npc:size_s":  { "minecraft:scale": { "value": 0.75 } },
      "npc:size_m":  { "minecraft:scale": { "value": 1.0 } },
      "npc:size_l":  { "minecraft:scale": { "value": 1.5 } },
      "npc:size_xl": { "minecraft:scale": { "value": 2.0 } },
      "npc:size_xxl":{ "minecraft:scale": { "value": 3.0 } },

      "npc:wander": {
        "minecraft:behavior.random_stroll": {
          "priority": 6,
          "speed_multiplier": 0.6
        }
      },
      "npc:frozen": {
        "minecraft:movement": { "value": 0.0 }
      },

      "npc:look_on": {
        "minecraft:behavior.look_at_player": {
          "priority": 7,
          "look_distance": 8.0,
          "probability": 0.9
        }
      },

      "npc:trader_on": {
        "minecraft:type_family": {
          "family": ["custom_npc", "npc", "mob", "trader"]
        }
      },

      "npc:hostile_on": {
        "minecraft:attack": { "damage": 0 },
        "minecraft:movement": { "value": 0.3 },
        "minecraft:behavior.melee_attack": {
          "priority": 3,
          "track_target": true,
          "reach_multiplier": 1.5
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 4,
          "must_see": true,
          "reselect_targets": true,
          "within_radius": 16,
          "entity_types": [
            {
              "filters": {
                "any_of": [
                  { "test": "is_family", "subject": "other", "value": "player" },
                  { "test": "is_family", "subject": "other", "value": "monster" }
                ]
              },
              "max_dist": 16
            }
          ]
        }
      },

      "npc:godmode_on": {
        "minecraft:damage_sensor": {
          "triggers": [
            {
              "cause": "all",
              "deals_damage": false
            }
          ]
        },
        "minecraft:fire_immune": {},
        "minecraft:knockback_resistance": { "value": 1.0, "max": 1.0 }
      }
    },

    "components": {
      "minecraft:type_family": {
        "family": ["custom_npc", "npc", "mob"]
      },
      "minecraft:collision_box": {
        "width": 0.6,
        "height": 1.8
      },
      "minecraft:health": {
        "value": 200,
        "max": 200
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:nameable": {
        "always_show": true,
        "allow_name_tag_renaming": true
      },
      "minecraft:persistent": {},
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_water": true
      },
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": false,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:interact": {
        "interactions": [
          {
            "on_interact": {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "player"
              },
              "event": "npc:noop",
              "target": "self"
            },
            "use_item": false,
            "swing": false,
            "play_sounds": "",
            "interact_text": "action.npc.edit"
          }
        ]
      },
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.random_look_around": { "priority": 9 }
    },

    "events": {
      "npc:noop": {},

      "minecraft:entity_spawned": {
        "sequence": [
          {
            "add": { "component_groups": ["npc:size_m", "npc:look_on", "npc:wander"] }
          }
        ]
      },

      "npc:size_xs": {
        "remove": { "component_groups": ["npc:size_s", "npc:size_m", "npc:size_l", "npc:size_xl", "npc:size_xxl"] },
        "add": { "component_groups": ["npc:size_xs"] }
      },
      "npc:size_s": {
        "remove": { "component_groups": ["npc:size_xs", "npc:size_m", "npc:size_l", "npc:size_xl", "npc:size_xxl"] },
        "add": { "component_groups": ["npc:size_s"] }
      },
      "npc:size_m": {
        "remove": { "component_groups": ["npc:size_xs", "npc:size_s", "npc:size_l", "npc:size_xl", "npc:size_xxl"] },
        "add": { "component_groups": ["npc:size_m"] }
      },
      "npc:size_l": {
        "remove": { "component_groups": ["npc:size_xs", "npc:size_s", "npc:size_m", "npc:size_xl", "npc:size_xxl"] },
        "add": { "component_groups": ["npc:size_l"] }
      },
      "npc:size_xl": {
        "remove": { "component_groups": ["npc:size_xs", "npc:size_s", "npc:size_m", "npc:size_l", "npc:size_xxl"] },
        "add": { "component_groups": ["npc:size_xl"] }
      },
      "npc:size_xxl": {
        "remove": { "component_groups": ["npc:size_xs", "npc:size_s", "npc:size_m", "npc:size_l", "npc:size_xl"] },
        "add": { "component_groups": ["npc:size_xxl"] }
      },

      "npc:move_on": {
        "remove": { "component_groups": ["npc:frozen"] },
        "add": { "component_groups": ["npc:wander"] }
      },
      "npc:move_off": {
        "remove": { "component_groups": ["npc:wander"] },
        "add": { "component_groups": ["npc:frozen"] }
      },

      "npc:look_on":  { "add": { "component_groups": ["npc:look_on"] } },
      "npc:look_off": { "remove": { "component_groups": ["npc:look_on"] } },

      "npc:trader_on":  { "add": { "component_groups": ["npc:trader_on"] } },
      "npc:trader_off": { "remove": { "component_groups": ["npc:trader_on"] } },

      "npc:hostile_on":  { "add": { "component_groups": ["npc:hostile_on"] } },
      "npc:hostile_off": { "remove": { "component_groups": ["npc:hostile_on"] } },

      "npc:godmode_on":  { "add": { "component_groups": ["npc:godmode_on"] } },
      "npc:godmode_off": { "remove": { "component_groups": ["npc:godmode_on"] } }
    }
  }
}
