{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "custom:npc_wand",
      "materials": { "default": "entity_alphatest" },
      "textures": { "default": "textures/entity/npc_wand" },
      "geometry": { "default": "geometry.npc_wand" },
      "scripts": {
        "pre_animation": [
          "v.main_hand = c.item_slot == 'main_hand';",
          "v.off_hand = c.item_slot == 'off_hand';",
          "v.head = c.item_slot == 'head';"
        ]
      },
      "render_controllers": [ "controller.render.npc_wand" ]
    }
  }
}
