{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "custom:npc_aura",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/npc_aura"
      }
    },
    "components": {
      "minecraft:emitter_local_space": { "position": true, "rotation": true, "velocity": false },
      "minecraft:emitter_rate_instant": { "num_particles": 1 },
      "minecraft:emitter_lifetime_once": { "active_time": 0.05 },
      "minecraft:particle_lifetime_expression": { "max_lifetime": 0.7 },
      "minecraft:particle_initial_speed": 0.1,
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, 1.5, 0],
        "linear_drag_coefficient": 1.5
      },
      "minecraft:particle_appearance_billboard": {
        "size": [0.14, 0.14],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 16,
          "texture_height": 16,
          "uv": [0, 0],
          "uv_size": [16, 16]
        }
      },
      "minecraft:particle_appearance_tinting": {
        "color": {
          "interpolant": "v.particle_age / v.particle_lifetime",
          "gradient": {
            "0.0": [0.45, 0.85, 1.0, 1.0],
            "0.5": [0.65, 0.6, 1.0, 0.8],
            "1.0": [0.8, 0.5, 1.0, 0.0]
          }
        }
      },
      "minecraft:particle_appearance_lighting": {}
    }
  }
}
