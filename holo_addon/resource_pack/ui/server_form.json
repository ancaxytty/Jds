{
  "namespace": "server_form",

  "long_form": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "default_long_form@common_dialogs.main_panel_no_buttons": {
          "$title_panel": "common_dialogs.standard_title_label",
          "$title_size": ["100% - 14px", 10],
          "size": [225, 200],
          "$text_name": "#title_text",
          "$title_text_binding_type": "none",
          "$child_control": "server_form.long_form_panel",
          "layer": 2,
          "bindings": [
            {
              "binding_name": "#title_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "((#title_text - 'Custom Form') = #title_text)",
              "target_property_name": "#visible"
            }
          ]
        }
      },
      {
        "custom_long_form@common_dialogs.main_panel_no_buttons": {
          "$title_panel": "common_dialogs.standard_title_label",
          "$title_size": ["100% - 14px", 10],
          "size": [360, 200],
          "$text_name": "#title_text",
          "$title_text_binding_type": "none",
          "$child_control": "server_form.holo_grid_main",
          "layer": 2,
          "bindings": [
            {
              "binding_name": "#title_text"
            },
            {
              "binding_type": "view",
              "source_property_name": "(#title_text = 'Custom Form')",
              "target_property_name": "#visible"
            }
          ]
        }
      }
    ]
  },

  "holo_grid_main": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
    "orientation": "vertical",
    "layer": 1,
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "scrolling_panel@common.scrolling_panel": {
          "anchor_to": "top_left",
          "anchor_from": "top_left",
          "$show_background": false,
          "size": ["100%", "100%"],
          "$scrolling_content": "server_form.holo_grid",
          "$scroll_size": [5, "100% - 4px"],
          "$scrolling_pane_size": ["100% - 4px", "100% - 2px"],
          "$scrolling_pane_offset": [2, 0],
          "$scroll_bar_right_padding_size": [0, 0]
        }
      }
    ]
  },

  "holo_grid": {
    "type": "panel",
    "size": ["100%", "100%c"],
    "controls": [
      {
        "holo_buttons_grid": {
          "type": "grid",
          "size": ["100%", "100%c"],
          "grid_dimensions": [3, 3],
          "grid_item_template": "server_form.holo_button",
          "grid_fill_direction": "horizontal",
          "grid_rescaling_type": "horizontal",
          "anchor_from": "center",
          "anchor_to": "center",
          "factory": {
            "name": "buttons",
            "control_name": "server_form.holo_button"
          },
          "collection_name": "form_buttons",
          "bindings": [
            {
              "binding_name": "#form_button_length",
              "binding_name_override": "#maximum_grid_items"
            }
          ]
        }
      }
    ]
  },

  "holo_button": {
    "type": "panel",
    "size": [110, 56],
    "controls": [
      {
        "main_ui": {
          "type": "panel",
          "size": [104, 50],
          "controls": [
            {
              "tile_bg": {
                "type": "image",
                "texture": "textures/holo_ui/btn_tile",
                "size": ["100%", "100%"],
                "alpha": 0.9,
                "layer": 1
              }
            },
            {
              "icon": {
                "type": "image",
                "layer": 5,
                "size": [40, 40],
                "offset": [8, 0],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "bindings": [
                  {
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_name": "#form_button_texture_file_system",
                    "binding_name_override": "#texture_file_system",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "label": {
                "type": "label",
                "text": "#form_button_text",
                "layer": 6,
                "color": [0.78, 0.95, 1.0],
                "offset": [54, 0],
                "size": [50, "default"],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "bindings": [
                  {
                    "binding_name": "#form_button_text",
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            },
            {
              "form_button@common_buttons.light_text_button": {
                "$pressed_button_name": "button.form_button_click",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "size": [104, 50],
                "layer": 8,
                "$button_text": "#null",
                "$button_text_binding_type": "collection",
                "$button_text_grid_collection_name": "form_buttons",
                "$button_text_max_size": ["100%", 20],
                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}
